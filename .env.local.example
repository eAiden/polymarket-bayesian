# Claude API (required for signal extraction)
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis (required for Vercel reads; optional for Railway-only deploy)
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Railway pipeline service URL (set on Vercel to proxy scan requests)
# Leave blank when running Railway-only or dev
PIPELINE_SERVICE_URL=https://your-pipeline.railway.app

# Admin secret — shared between Vercel and Railway to auth /admin/* endpoints
ADMIN_SECRET=change-me-to-a-random-string

# Show "Run Scan" button in the UI (set to "true" in dev and Railway; leave unset on public Vercel)
NEXT_PUBLIC_SHOW_SCAN=true

# Optional enrichment APIs
FRED_API_KEY=
NEWSDATA_API_KEY=
CRYPTOPANIC_API_KEY=
